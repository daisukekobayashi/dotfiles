#!/usr/bin/env bash
set -euo pipefail

pause() {
  printf 'Press Enter to close...'
  read -r _ || true
}

if ! command -v eza >/dev/null 2>&1; then
  printf 'eza is not installed or not on PATH\n'
  pause
  exit 0
fi

set +e
eza --tree --git --group-directories-first --level=3 .
status="$?"
set -e

printf '\nExit status: %s\n' "${status}"
pause
exit "${status}"
