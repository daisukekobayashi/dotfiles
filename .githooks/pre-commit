#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

case "$(uname -s 2>/dev/null || printf unknown)" in
  MINGW* | MSYS* | CYGWIN*)
    if command -v pwsh >/dev/null 2>&1; then
      pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/check-skills-build.ps1
    elif command -v powershell >/dev/null 2>&1; then
      powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-skills-build.ps1
    else
      scripts/check-skills-build.sh
    fi
    ;;
  *)
    scripts/check-skills-build.sh
    ;;
esac
